  },
  "peerDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^31.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "undici-types": "^6.21.0",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
