{
  "name": "codex-headless",
  "version": "0.1.0",
  "description": "Programmatically control OpenAI Codex through a headless terminal \u2014 structured JSON events, automated commands, async streaming API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
