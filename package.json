{
  "name": "codex-headless",
  "version": "0.1.0",
  "description": "Programmatically control OpenAI Codex through a headless terminal — structured JSON events, automated commands, async streaming API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test:fresh-rollout-claim": "vitest run src/transcript/RolloutOwnership.test.ts -t fresh",
    "test:resume-fork-candidate": "vitest run src/transcript/RolloutOwnership.test.ts -t resumed",
    "debugger": "electron src/debugger/main.mjs",
    "upstream:check": "node scripts/check-upstream.mjs",
    "test": "vitest run",
    "test:core": "vitest run --project core",
    "test:system": "vitest run --project system",
    "test:live": "vitest run --config vitest.live.config.ts --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:package": "npm run build && node scripts/test-package.mjs",
    "test:contract": "node scripts/check-test-contract.mjs",
    "check": "npm run test:contract && npm run typecheck && npm test && npm run test:package"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0"
  },
  "peerDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^31.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "undici-types": "^6.21.0",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
